import os
import re
import pickle
import hashlib
import numpy as np
from pathlib import Path
from typing import List, Tuple, Dict

# PDF reading
try:
    import fitz  # PyMuPDF
    PDF_BACKEND = "pymupdf"
except ImportError:
    PDF_BACKEND = None

# Embeddings / retrieval
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity


# ── Text Extraction ───────────────────────────────────────────────────────────
def extract_text_from_pdf(pdf_path: str) -> str:
    """Extract raw text from a PDF file."""
    if PDF_BACKEND == "pymupdf":
        doc  = fitz.open(pdf_path)
        text = "\n".join(page.get_text() for page in doc)
        doc.close()
        return text
    else:
        raise RuntimeError("PyMuPDF not installed. Run: pip install pymupdf")


# ── Chunking ──────────────────────────────────────────────────────────────────
def chunk_text(text: str,
               chunk_size: int = 400,
               overlap: int = 80) -> List[str]:
    """
    Split text into overlapping word-level chunks.
    Overlap ensures context isn't lost at boundaries.
    """
    words  = text.split()
    chunks = []
    start  = 0
    while start < len(words):
        end   = min(start + chunk_size, len(words))
        chunk = " ".join(words[start:end])
        if len(chunk.strip()) > 30:          # skip tiny fragments
            chunks.append(chunk.strip())
        start += chunk_size - overlap
    return chunks


# ── Vector Store ──────────────────────────────────────────────────────────────
class VectorStore:
    """
    Lightweight TF-IDF vector store with cosine similarity retrieval.
    No external API needed — runs 100% locally.
    """

    def __init__(self):
        self.vectorizer = TfidfVectorizer(
            max_features=20_000,
            ngram_range=(1, 2),
            sublinear_tf=True,
            stop_words="english",
        )
        self.vectors: np.ndarray = None
        self.chunks:  List[str]  = []
        self.metadata: List[Dict] = []

    def build(self, chunks: List[str], metadata: List[Dict] = None):
        """Index a list of text chunks."""
        self.chunks   = chunks
        self.metadata = metadata or [{} for _ in chunks]
        self.vectors  = self.vectorizer.fit_transform(chunks)
        print(f"  ✅ Indexed {len(chunks)} chunks  |  "
              f"vocab size: {len(self.vectorizer.vocabulary_):,}")

    def retrieve(self, query: str, top_k: int = 5) -> List[Tuple[str, float, Dict]]:
        """Return top-k most relevant chunks for a query."""
        q_vec  = self.vectorizer.transform([query])
        scores = cosine_similarity(q_vec, self.vectors).flatten()
        top_idx = np.argsort(scores)[::-1][:top_k]
        results = []
        for idx in top_idx:
            if scores[idx] > 0.01:           # ignore irrelevant chunks
                results.append((self.chunks[idx], float(scores[idx]), self.metadata[idx]))
        return results

    def save(self, path: str):
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "wb") as f:
            pickle.dump(self, f)

    @staticmethod
    def load(path: str) -> "VectorStore":
        with open(path, "rb") as f:
            return pickle.load(f)


# ── Answer Generation ─────────────────────────────────────────────────────────
def build_prompt(query: str, context_chunks: List[str]) -> str:
    context = "\n\n---\n\n".join(
        f"[Chunk {i+1}]\n{chunk}" for i, chunk in enumerate(context_chunks)
    )
    return f"""You are a precise research assistant. Answer the question below
using ONLY the context provided. If the answer is not in the context, say
"I could not find this information in the document."

CONTEXT:
{context}

QUESTION: {query}

ANSWER (cite which chunk(s) support your answer):"""


def generate_answer_local(query: str, context_chunks: List[str]) -> str:
    """
    Rule-based answer generation — works without any API key.
    For production: swap this for an LLM call (Ollama / Claude / OpenAI).
    """
    if not context_chunks:
        return "I could not find relevant information in the document for this query."

    # Find sentences containing query keywords
    keywords = set(re.sub(r"[^\w\s]", "", query.lower()).split()) - {
        "what", "who", "when", "where", "how", "why", "is", "are",
        "the", "a", "an", "in", "of", "to", "and", "for"
    }

    best_sentences = []
    for chunk in context_chunks:
        sentences = re.split(r"(?<=[.!?])\s+", chunk)
        for sent in sentences:
            sent_lower = sent.lower()
            hits = sum(1 for kw in keywords if kw in sent_lower)
            if hits > 0:
                best_sentences.append((hits, sent.strip()))

    best_sentences.sort(key=lambda x: -x[0])
    top_sentences = [s for _, s in best_sentences[:4]]

    if top_sentences:
        answer = " ".join(top_sentences)
        return f"{answer}\n\n_(Based on {len(context_chunks)} retrieved chunks)_"
    else:
        # Fallback: return first 2 sentences of the most relevant chunk
        first_chunk = context_chunks[0]
        sentences   = re.split(r"(?<=[.!?])\s+", first_chunk)
        return " ".join(sentences[:2]) + "\n\n_(Most relevant passage found)_"


# ── Main RAG Pipeline ─────────────────────────────────────────────────────────
class RAGPipeline:

    def __init__(self, index_dir: str = "data/index"):
        self.index_dir = index_dir
        self.store: VectorStore = None

    def ingest(self, pdf_path: str) -> int:
        """Load a PDF, chunk it, and build the vector index."""
        print(f"\n📄 Ingesting: {pdf_path}")
        text   = extract_text_from_pdf(pdf_path)
        print(f"  Extracted {len(text):,} characters")

        chunks = chunk_text(text, chunk_size=400, overlap=80)
        print(f"  Split into {len(chunks)} chunks")

        # Attach page-level metadata (approximate)
        words_per_page = 300
        metadata = []
        for i, chunk in enumerate(chunks):
            approx_page = (i * 400) // words_per_page + 1
            metadata.append({"chunk_id": i, "approx_page": approx_page,
                              "source": Path(pdf_path).name})

        self.store = VectorStore()
        self.store.build(chunks, metadata)

        # Cache index for reuse
        pdf_hash   = hashlib.md5(Path(pdf_path).read_bytes()).hexdigest()[:8]
        index_path = os.path.join(self.index_dir, f"{pdf_hash}.pkl")
        self.store.save(index_path)
        print(f"  💾 Index cached → {index_path}")
        return len(chunks)

    def ask(self, query: str, top_k: int = 5) -> Dict:
        """Ask a question and get an answer with sources."""
        if self.store is None:
            raise RuntimeError("No document loaded. Call ingest() first.")

        results = self.store.retrieve(query, top_k=top_k)
        if not results:
            return {
                "query":   query,
                "answer":  "No relevant content found in the document.",
                "sources": [],
                "scores":  [],
            }

        context_chunks = [r[0] for r in results]
        scores         = [r[1] for r in results]
        meta           = [r[2] for r in results]

        answer = generate_answer_local(query, context_chunks)

        return {
            "query":          query,
            "answer":         answer,
            "context_chunks": context_chunks,
            "scores":         scores,
            "metadata":       meta,
        }
